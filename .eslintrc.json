{
  "extends": ["airbnb-base", "prettier"],
  "rules": {
    "no-underscore-dangle": 0,
    "no-constructor-return": 0,
    "max-len": "warn",
    "no-plusplus": 0,
    "eol-last": ["error", "always"],
    "class-methods-use-this": "off",
    "curly": ["error", "all"],
    "func-names": 0
  },
  "overrides": [
    {
      "files": ["test/browser.e2e.spec.mjs"],
      "env": {
        "browser": true,
        "es2022": true
      },
      "globals": {
        "window": "readonly"
      },
      "rules": {
        "no-new": "off"
      }
    }
  ]
}