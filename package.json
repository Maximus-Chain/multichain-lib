{
  "name": "@maximus-chain/multichain-lib",
  "version": "2.1.1",
  "description": "A multi-chain cryptocurrency primitives library. Built-in support for MaximusChain; register custom chains.",
  "author": "MaximusChain",
  "main": "index.js",
  "module": "dist/multichain-lib.mjs",
  "unpkg": "dist/multichain-lib.min.js",
  "scripts": {
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:types && npm run test:node && npm run test:browser",
    "test:node": "vitest run",
    "test:browser": "npm run build && npx playwright test --config=playwright.config.mjs --project=chromium",
    "test:e2e": "npx playwright test",
    "test:types": "npx tsd",
    "coverage": "vitest run --coverage",
    "build": "webpack",
    "pretty": "npx prettier --write ."
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "lib",
    "typings",
    "index.d.ts"
  ],
  "keywords": [
    "multichain",
    "maximuschain",
    "maximus",
    "transaction",
    "address",
    "p2p",
    "cryptocurrency",
    "blockchain",
    "payment",
    "bip21",
    "bip32",
    "bip37",
    "bip69",
    "multisig"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maximus-Chain/multichain-lib.git"
  },
  "types": "index.d.ts",
  "bugs": {
    "url": "https://github.com/Maximus-Chain/multichain-lib/issues"
  },
  "homepage": "https://github.com/Maximus-Chain/multichain-lib",
  "dependencies": {
    "@dashevo/bls": "^1.3.6",
    "@dashevo/x11-hash-js": "^1.0.2",
    "bloom-filter": "^0.2.0",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "elliptic": "^6.5.4",
    "inherits": "^2.0.4",
    "lodash": "^4.17.20",
    "ripemd160": "^2.0.2",
    "unorm": "^1.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bloom-filter": "^0.2.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "assert-browserify": "^2.0.0",
    "brfs-node-15": "^2.0.3",
    "buffer": "^6.0.3",
    "chai": "^6.2.2",
    "crypto-browserify": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "http-server": "^14.1.1",
    "mocha": "^11.3.0",
    "nyc": "^14.1.1",
    "path-browserify": "^1.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "raw-loader": "^4.0.1",
    "sinon": "^21.1.2",
    "stream-browserify": "^3.0.0",
    "terser-webpack-plugin": "^5.5.0",
    "transform-loader": "^0.2.4",
    "tsd": "^0.33.0",
    "url": "^0.11.0",
    "vitest": "^4.1.5",
    "wasm-x11-hash": "^0.0.2",
    "webpack": "^5.76.2",
    "webpack-cli": "^7.0.2"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
